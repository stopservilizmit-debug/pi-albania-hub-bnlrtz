
{
  "expo": {
    "name": "Pi Albania Hub",
    "slug": "pi-albania-hub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/SvWdlmilRmaWvwHT_aZVJQ@2k.webp",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/SvWdlmilRmaWvwHT_aZVJQ@2k.webp",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pialbania.hub",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/SvWdlmilRmaWvwHT_aZVJQ@2k.webp",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.pialbania.hub"
    },
    "web": {
      "favicon": "./assets/images/final_quest_240x240.png",
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser"
    ],
    "scheme": "pialbaniahub",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://5jj9frgc7vncgryytacv4eax7sz9j77c.app.specular.dev"
    }
  }
}
